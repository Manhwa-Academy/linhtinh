{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "outputDirectory": ".",
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/uploadthing", "destination": "/api/uploadthing.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" }
  ]
}
